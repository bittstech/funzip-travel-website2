generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MediaAssetType {
  HERO
  GALLERY
  PACKAGE
  BLOG
  OG_IMAGE
  GENERAL
}

model SiteSettings {
  id                     String   @id @default(cuid())
  siteName               String   @default("Funzip Kashmir Tour & Travels")
  siteUrl                String   @default("https://funzip.travel")
  logoUrl                String?
  phonePrimary           String?
  phoneSecondary         String?
  whatsappNumber         String?
  email                  String?
  address                String?
  googleReviewUrl        String?
  tripAdvisorUrl         String?
  defaultMetaTitle       String?
  defaultMetaDescription String?
  defaultOgImage         String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model MediaAsset {
  id               String         @id @default(cuid())
  originalFileName String
  altText          String?
  caption          String?
  storageUrl       String
  variantsJson     Json?
  width            Int
  height           Int
  format           String
  sizeKb           Int
  type             MediaAssetType @default(GENERAL)
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  heroSlides       HeroSlide[]    @relation("HeroSlideImage")
  mobileHeroSlides HeroSlide[]    @relation("HeroSlideMobileImage")
  galleryImages    GalleryImage[]
  packageCovers    Package[]      @relation("PackageCover")
  packageOgImages  Package[]      @relation("PackageOgImage")
  blogCovers       Blog[]         @relation("BlogCover")
  blogOgImages     Blog[]         @relation("BlogOgImage")

  @@index([type, isActive])
}

model HeroSlide {
  id            String      @id @default(cuid())
  title         String
  subtitle      String?
  imageId       String
  mobileImageId String?
  ctaText       String?
  ctaUrl        String?
  sortOrder     Int         @default(0)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  image         MediaAsset  @relation("HeroSlideImage", fields: [imageId], references: [id], onDelete: Restrict)
  mobileImage   MediaAsset? @relation("HeroSlideMobileImage", fields: [mobileImageId], references: [id], onDelete: SetNull)

  @@index([isActive, sortOrder])
}

model GalleryImage {
  id        String     @id @default(cuid())
  imageId   String
  title     String?
  location  String?
  altText   String?
  sortOrder Int        @default(0)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  image     MediaAsset @relation(fields: [imageId], references: [id], onDelete: Restrict)

  @@index([isActive, sortOrder])
}

model Package {
  id                String      @id @default(cuid())
  title             String
  slug              String      @unique
  shortDescription  String
  fullDescription   String?
  itineraryUrl      String?
  location          String?
  duration          String?
  priceStartingFrom Int?
  coverImageId      String?
  galleryImageIds   Json        @default("[]")
  services          Json        @default("[]")
  highlights        Json        @default("[]")
  mustKnow          Json        @default("[]")
  inclusions        Json        @default("[]")
  exclusions        Json        @default("[]")
  itineraryJson     Json        @default("[]")
  faqsJson          Json        @default("[]")
  metaTitle         String?
  metaDescription   String?
  ogImageId         String?
  canonicalUrl      String?
  keywords          Json        @default("[]")
  isFeatured        Boolean     @default(false)
  isPublished       Boolean     @default(false)
  publishedAt       DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  coverImage        MediaAsset? @relation("PackageCover", fields: [coverImageId], references: [id], onDelete: SetNull)
  ogImage           MediaAsset? @relation("PackageOgImage", fields: [ogImageId], references: [id], onDelete: SetNull)

  @@index([isPublished, isFeatured])
  @@index([publishedAt])
}

model Blog {
  id              String      @id @default(cuid())
  title           String
  slug            String      @unique
  excerpt         String
  content         String?
  coverImageId    String?
  authorName      String?
  category        String?
  tags            Json        @default("[]")
  faqsJson        Json        @default("[]")
  metaTitle       String?
  metaDescription String?
  ogImageId       String?
  canonicalUrl    String?
  isPublished     Boolean     @default(false)
  publishedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  coverImage      MediaAsset? @relation("BlogCover", fields: [coverImageId], references: [id], onDelete: SetNull)
  ogImage         MediaAsset? @relation("BlogOgImage", fields: [ogImageId], references: [id], onDelete: SetNull)

  @@index([isPublished, publishedAt])
  @@index([category])
}

model Lead {
  id              String   @id @default(cuid())
  name            String
  phone           String
  travelLocation  String?
  numberOfPeople  Int?
  sourcePage      String
  sourceType      String
  message         String?
  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([sourceType])
}
